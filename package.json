{
  "name": "affiliate-system",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern node_modules --ignore-pattern .next --ignore-pattern output",
    "typecheck": "tsc --noEmit",
    "db:verify": "node --experimental-strip-types scripts/verify-migrations.ts",
    "audit:buttons": "node --experimental-strip-types scripts/audit-buttons.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --trace on --video on --screenshot on",
    "test:e2e:ui": "playwright test --ui",
    "qa:reports": "node --experimental-strip-types scripts/generate-live-test-reports.ts"
  },
  "dependencies": {
    "@upstash/qstash": "^2.11.1",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.468.0",
    "next": "16.2.6",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^22.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.23",
    "knip": "^6.24.0",
    "postcss": "^8",
    "postcss-load-config": "^6.0.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^16.2.6"
  }
}
